pipeline {
    agent any

    stages {

        stage('Check Network') {
            steps {
                sh '''
                set -e
                echo "DNS test:"
                getent hosts download.docker.com || true

                echo "Curl test:"
                curl -I https://download.docker.com || true
                '''
            }
        }

        stage('Install Docker') {
            steps {
                sh '''
                set -e

                sudo apt-get update
                sudo apt-get install -y ca-certificates curl gnupg lsb-release

                sudo install -m 0755 -d /etc/apt/keyrings

                # Retry curl (important en CI)
                for i in 1 2 3; do
                    curl -fsSL https://download.docker.com/linux/ubuntu/gpg && break
                    echo "Retry $i..."
                    sleep 3
                done | sudo gpg --batch --yes --dearmor -o /etc/apt/keyrings/docker.gpg

                sudo chmod a+r /etc/apt/keyrings/docker.gpg

                echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

                sudo apt-get update

                sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

                sudo systemctl enable docker
                sudo systemctl start docker
                '''
            }
        }

        stage('Verify Docker') {
            steps {
                sh 'docker --version'
            }
        }
    }
}
