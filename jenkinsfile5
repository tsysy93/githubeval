pipeline {
    agent any

    stages {

         stage('Checkout-SCM') {
            steps {
                git branch: 'main', url: 'https://github.com/tsysy93/githubeval/'
            }
        }

        stage('Clean Docker') {
            steps {
                sh '''
                docker stop $(docker ps -aq) || true
                docker rm $(docker ps -aq) || true
                docker rmi $(docker images -q) || true
                '''
            }
        }

        stage('Install Docker') {
            steps {
                sh 'sudo apt install docker.io -y'
                sh 'sudo systemctl start docker'
            }
        }

        stage('Clone') {
            steps {
                git branch: 'main', url: 'https://github.com/tsysy93/githubeval.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t mon-nginx .'
            }
        }

        stage('Run') {
            steps {
                sh 'docker run -d --name myapp -p 8081:80 mon-nginx'
            }
        }

        stage('Copy site') {
            steps {
                sh '''
                    docker cp index.html myapp:/usr/share/nginx/html/index.html
                '''
            }
        }
    }
}
