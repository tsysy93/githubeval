pipeline {
    agent any

    environment {
        IMAGE_NAME = 'mon-nginx'
        CONTAINER_NAME = 'myapp'
        PORT = '8081'
    }

    stages {
        

        stage('Install Docker') {
            steps {
                // Vérification et installation de Docker si nécessaire
                sh 'sudo apt update && sudo apt install -y docker.io'
                sh 'sudo systemctl enable --now docker'
            }
        }

        stage('Clone') {
            steps {
                // Clonage du repository
                git branch: 'main', url: 'https://github.com/tsysy93/githubeval.git'
            }
        }

        stage('Build') {
            steps {
                // Construction de l'image Docker
                sh 'docker build -t ${IMAGE_NAME} .'
            }
        }

        stage('Run') {
            steps {
                // Exécution du conteneur avec le port exposé
                sh '''
                if [ ! "$(docker ps -q -f name=${CONTAINER_NAME})" ]; then
                    docker run -d --name ${CONTAINER_NAME} -p ${PORT}:80 ${IMAGE_NAME}
                else
                    echo "Container ${CONTAINER_NAME} is already running."
                fi
                '''
            }
        }

        stage('Stop and Remove Container') {
            steps {
                // Arrêter et supprimer le conteneur avant le prochain stage
                sh '''
                docker stop ${CONTAINER_NAME} || true
                docker rm ${CONTAINER_NAME} || true
                '''
            }
        }

        stage('Copy site') {
            steps {
                // Copie de index.html dans le conteneur Nginx
                sh '''
                    docker cp index.html ${CONTAINER_NAME}:/usr/share/nginx/html/index.html
                '''
            }
        }

        stage('Stop and Remove Container Again') {
            steps {
                // Arrêter et supprimer le conteneur après la copie
                sh '''
                docker stop ${CONTAINER_NAME} || true
                docker rm ${CONTAINER_NAME} || true
                '''
            }
        }
    }

    post {
        always {
            // Nettoyage après exécution du pipeline (optionnel)
            echo 'Pipeline terminé.'
        }
        success {
            // Actions à prendre si le pipeline réussit
            echo 'Pipeline exécuté avec succès.'
        }
        failure {
            // Actions à prendre en cas d’échec du pipeline
            echo 'Échec du pipeline.'
        }
    }
}
